# Copy this file to .env.local and fill in your values.
# .env.local is gitignored and never committed.
# It is included in gcloud builds submit tarballs (see .gcloudignore) so that
# NEXT_PUBLIC_* vars are available when `next build` runs in Cloud Build.

# ---- Firebase (client SDK) -----------------------------------------------
# Find these in Firebase Console > Project Settings > Your apps > Web app.
# These are public client identifiers, not service account credentials.
NEXT_PUBLIC_FIREBASE_API_KEY=AIzaSy...
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=your-project-id
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=your-project.firebasestorage.app
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=000000000000
NEXT_PUBLIC_FIREBASE_APP_ID=1:000000000000:web:abc123

# ---- Google Maps ----------------------------------------------------------
# Create an API key in GCP Console > APIs & Services > Credentials.
# Restrict it to the Maps JavaScript API and your domain.
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=AIzaSy...
